# Docker Compose project and host ports. These defaults do not replace the
# existing `translatrix-pro-intergrated` stack.
COMPOSE_PROJECT_NAME=translatrix-pro
FRONTEND_HOST_PORT=8081
BACKEND_HOST_PORT=8001

# Local Docker defaults. Replace before any shared or production deployment.
POSTGRES_DB=translatrix_pro
POSTGRES_USER=translatrix
POSTGRES_PASSWORD=translatrix_password
SECRET_KEY=development-secret-key-minimum-32-characters-long
JWT_SECRET_KEY=development-jwt-secret-minimum-32-characters
SUPER_ADMIN_PASSWORD=DevOnly!2026
DEV_SEED_PASSWORD=DevOnly!2026
